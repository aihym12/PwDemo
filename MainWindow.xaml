<Window x:Class="PwDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PwDemo - Playwright Element Extractor"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    <DockPanel LastChildFill="True">

        <!-- Top toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <TextBlock Text="URL:" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox x:Name="UrlTextBox"
                     Width="480"
                     Text="https://example.com"
                     VerticalAlignment="Center"/>
            <Button x:Name="LaunchButton"
                    Content="Launch Browser"
                    Margin="8,0,0,0"
                    Click="LaunchButton_Click"/>
            <Button x:Name="NavigateButton"
                    Content="Navigate"
                    Margin="4,0,0,0"
                    Click="NavigateButton_Click"/>
            <Separator/>
            <Button x:Name="ExtractButton"
                    Content="Extract Elements"
                    Click="ExtractButton_Click"/>
            <Button x:Name="SimplifyButton"
                    Content="Simplify HTML"
                    Margin="4,0,0,0"
                    Click="SimplifyButton_Click"/>
            <Separator/>
            <Button x:Name="CloseBrowserButton"
                    Content="Close Browser"
                    Click="CloseBrowserButton_Click"/>
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 4-panel layout -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Top-left: HTML input (raw page HTML) -->
            <GroupBox Grid.Row="0" Grid.Column="0" Header="Raw HTML (input)">
                <TextBox x:Name="RawHtmlTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>
            </GroupBox>

            <!-- Top-right: simplified HTML -->
            <GroupBox Grid.Row="0" Grid.Column="2" Header="Simplified HTML">
                <TextBox x:Name="SimplifiedHtmlTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>
            </GroupBox>

            <!-- Bottom-left: JSON elements -->
            <GroupBox Grid.Row="2" Grid.Column="0" Header="Elements (JSON)">
                <TextBox x:Name="ElementsJsonTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>
            </GroupBox>

            <!-- Bottom-right: log -->
            <GroupBox Grid.Row="2" Grid.Column="2" Header="Log">
                <TextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>
            </GroupBox>

            <GridSplitter Grid.Row="1" Grid.ColumnSpan="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="LightGray"/>
            <GridSplitter Grid.Column="1" Grid.RowSpan="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="LightGray"/>
        </Grid>
    </DockPanel>
</Window>
