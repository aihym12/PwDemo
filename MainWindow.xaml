<Window x:Class="PwDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HTML 精简工具"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    <DockPanel LastChildFill="True">

        <!-- 顶部工具栏 -->
        <ToolBar DockPanel.Dock="Top">
            <Button x:Name="SimplifyButton"
                    Content="精简 HTML"
                    Click="SimplifyButton_Click"/>
            <Button x:Name="CopyButton"
                    Content="复制结果"
                    Margin="4,0,0,0"
                    Click="CopyButton_Click"/>
            <Separator/>
            <Button x:Name="ClearButton"
                    Content="清空"
                    Click="ClearButton_Click"/>
        </ToolBar>

        <!-- 状态栏 -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 左右两栏：输入/输出 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：原始 HTML（粘贴输入） -->
            <GroupBox Grid.Column="0" Header="原始 HTML（请粘贴到此处）">
                <TextBox x:Name="RawHtmlTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>
            </GroupBox>

            <!-- 右侧：精简后的 HTML -->
            <GroupBox Grid.Column="2" Header="精简后的 HTML">
                <TextBox x:Name="SimplifiedHtmlTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="LightGray"/>
        </Grid>
    </DockPanel>
</Window>
