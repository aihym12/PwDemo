<Window x:Class="PwDemo.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="精简统计"
        Height="480" Width="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12" LastChildFill="True">

        <!-- 顶部：总体字符数统计 -->
        <Border DockPanel.Dock="Top"
                BorderBrush="LightGray"
                BorderThickness="1"
                Padding="10"
                CornerRadius="4"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="原始字符数：" Margin="0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OriginalLengthText" Margin="8,2,0,2" FontWeight="Bold"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="精简后字符数：" Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SimplifiedLengthText" Margin="8,2,0,2" FontWeight="Bold"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="精简字符数：" Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RemovedLengthText" Margin="8,2,0,2" FontWeight="Bold" Foreground="DarkGreen"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="精简比例：" Margin="0,2"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RemovedRatioText" Margin="8,2,0,2" FontWeight="Bold" Foreground="DarkGreen"/>
            </Grid>
        </Border>

        <!-- 底部：关闭按钮 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="关闭" Width="80" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>

        <!-- 中间：精简了哪些内容 -->
        <GroupBox Header="精简了哪些内容">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="6">
                    <TextBlock Text="删除的标签（整段节点）" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="RemovedTagsText" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <TextBlock Text="删除的属性" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="RemovedAttrsText" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </DockPanel>
</Window>
